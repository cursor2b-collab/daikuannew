# Supabase（与现有部署一致）
NEXT_PUBLIC_SUPABASE_URL=https://zjodvwgmwwgixwpyuvos.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_Fy16nfH8omr46sGvBzisEg_wq3UWtuc

# 管理后台写库（创建用户、生成验证码、清空等）必须配置，否则会报 500/权限错误
# 在 Supabase 控制台 Project Settings -> API 中复制 service_role key（勿泄露）
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Telegram 登录群组通知（可选；也可在管理后台「系统设置 - Telegram 通知」中配置）
# 用户登录后，机器人会向指定群组发送：登录用户姓名、手机号、欠款金额、逾期天数
# TELEGRAM_BOT_TOKEN=你的Bot Token（在 @BotFather 创建机器人后获得）
# TELEGRAM_CHAT_ID=群组 Chat ID（将机器人拉入群组后获得，通常为 -100xxxxxxxxxx）

# 图形验证码密钥（用于签发/校验图形验证码，生产环境请修改）
# CAPTCHA_SECRET=随机长字符串

# 短信宝（可选；也可在管理后台「系统设置 - 短信配置」中配置）
# 接口：https://api.smsbao.com/sms?u={用户名}&p={密码或ApiKey}&m={手机号}&c={内容URL编码}
# 用于发送登录短信验证码。不配置时不会真实发送（开发环境会模拟）。
# SMSBAO_USERNAME=短信宝用户名
# SMSBAO_PASSWORD=登录密码或 32 位 ApiKey（推荐 ApiKey）
# SMSBAO_GOODS_ID=专用通道产品 ID（可选）
# SMSBAO_CONTENT_TEMPLATE=短信内容模板，用 {code} 表示验证码（可选，不填则用后台配置或默认）
